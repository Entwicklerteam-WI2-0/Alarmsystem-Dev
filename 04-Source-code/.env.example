# Kopiere diese Datei zu .env und passe die Werte an.
# .env wird NICHT committet (Secrets, NF-07). Hier stehen nur Platzhalter.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alarmsystem
DB_USER=alarm
DB_PASSWORD=changeme
# Hinweis: Der Connection-Helper nutzt bewusst nur diesen Least-Privilege-App-User
# (NF-07). Es gibt KEIN DB_ROOT_PASSWORD hier - das initiale DB-/Schema-Setup
# (CREATE DATABASE/USER, schema.sql; DTB-54) ist ein separater Admin-Schritt mit
# eigenen Zugangsdaten und gehoert nicht in die Laufzeit-Config der App.

# Optionale Verbindungsparameter (technische Defaults, bewusst gesetzt).
# autocommit=false erlaubt atomare Transaktionen ueber storage.database.transaction().
DB_CONNECT_TIMEOUT=5
DB_AUTOCOMMIT=false
DB_CHARSET=utf8mb4

# --- Laufzeit / Scheduler (DTB-64) ---
# G1-Sensor-API, die G2 pollt. Default ist http:// im abgeschlossenen Intranet
# (akzeptabel). Sobald G1 ein Zertifikat bereitstellt, hier auf HTTPS umstellen:
#   G1_BASE_URL=https://g1-sensorik.local
G1_BASE_URL=http://g1-sensorik.local
# Hintergrund-Scheduler ist standardmaessig AUS (der Stub laeuft ohne DB/G1).
# Erst nach DB-/G1-Verdrahtung scharfschalten: 1/true/yes/on.
G2_ENABLE_SCHEDULER=false
# Poll-Intervall: wird aus der Config geladen (thresholds.json -> betrieb.poll_interval_s),
# NICHT aus einer Env-Variable. (Frueheres G2_POLL_INTERVAL_S entfernt - wurde nie gelesen.)

# --- Schreibschutz / Auth (DTB-63, NF-07) ---
# API-Key fuer die schreibenden /v1-Endpoints (PUT /v1/thresholds). Beim Aufruf als
# 'Authorization: Bearer <key>' senden. Ist die Variable NICHT gesetzt, ist der
# Schreibzugriff fail-safe-closed (jede Schreibanfrage -> 503) — nie im Code/Repo!
G2_API_KEY=changeme-write-key
# Verschluesselung (NF-07): TLS wird am Reverse-Proxy terminiert (Deployment-
# Anforderung), nicht in der App. Hinter dem Proxy erreichen Clients die schreibenden
# Endpoints ausschliesslich ueber HTTPS; fuer lokale Entwicklung entfaellt das.
